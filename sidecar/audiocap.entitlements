<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Entitlements for the audiocap sidecar under the hardened runtime. It opens
     the microphone (AVAudioEngine) and the Core Audio process tap for system
     audio; audio-input covers the mic. The system-audio tap is gated by the
     runtime-granted Screen & System Audio Recording permission, not an
     entitlement. -->
<plist version="1.0">
<dict>
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
