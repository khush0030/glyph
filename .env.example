# Glyph credentials — copy to `.env` and fill in.
#
# WHERE THIS GOES:
#   • Development (running from source): keep this `.env` at the repo root.
#   • Installed app (.dmg): put the file at
#       ~/Library/Application Support/ai.oltaflock.glyph/.env
#
# If a `.env` is found, Glyph reads secrets from it and never touches the macOS
# Keychain. It is gitignored — keep it out of the repo.
# Note: values are stored as PLAINTEXT on disk.
#
# Var name == credential id, uppercased.

# Anthropic Claude — REQUIRED for note generation (summary / action items).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Calendar OAuth client — OPTIONAL (only for the Calendar feature).
GOOGLE_OAUTH_CLIENT_ID=
# Only needed if your Google client requires a secret at token exchange.
GOOGLE_OAUTH_CLIENT_SECRET=

# Asana token — OPTIONAL (only to push action items to Asana).
ASANA_ACCESS_TOKEN=

# ElevenLabs — NO LONGER USED. Speech-to-text now runs locally (whisper.cpp).
# ELEVENLABS_API_KEY=
