# Glyph credentials — copy to `.env` and fill in.
#
# If a `.env` file exists, Glyph reads secrets from here and NEVER touches the
# macOS Keychain. The `.env` file is gitignored — keep it out of the repo.
# Note: these are stored as PLAINTEXT on disk (weaker than the Keychain).
#
# Var name == credential id, uppercased.

# ElevenLabs Scribe v2 (STT)
ELEVENLABS_API_KEY=

# Anthropic Claude (note generation)
ANTHROPIC_API_KEY=

# Google Calendar OAuth client
GOOGLE_OAUTH_CLIENT_ID=
# Only needed if your Google Desktop client requires a secret at token exchange
GOOGLE_OAUTH_CLIENT_SECRET=

# Asana personal access token / OAuth token
ASANA_ACCESS_TOKEN=
